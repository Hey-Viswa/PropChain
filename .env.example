# ─────────────────────────────────────────────────────────────────────────────
# PropChain environment variables — copy to .env.local and fill in.
# EVERY service below has a FREE tier. No paid plan is required for the PoC.
# Anything left blank degrades gracefully (simulated IPFS CID, logged emails,
# empty on-chain history, free OpenStreetMap map fallback).
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth: Clerk (free tier) ──────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Clerk Dashboard → Webhooks → add endpoint /api/webhooks/clerk → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxx

# ── Database: MongoDB Atlas (free M0 cluster) ────────────────────────────────
# https://cloud.mongodb.com → create free M0 → Database Access + Network Access
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/propchain?retryWrites=true&w=majority

# ── Blockchain: Polygon Amoy testnet (free) ──────────────────────────────────
# Mumbai was sunset in 2024 — use Amoy (chainId 80002). Free RPC works out of
# the box; for higher limits get a free Alchemy/Infura key.
NEXT_PUBLIC_CHAIN_ID=80002
BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
NEXT_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# Deployer key — a THROWAWAY testnet wallet only. Never a real funded key.
DEPLOYER_PRIVATE_KEY=
ADMIN_WALLET_PRIVATE_KEY=
# Filled in after `npx hardhat run scripts/deploy.ts --network amoy`
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_ENCUMBRANCE_ADDRESS=
NEXT_PUBLIC_DISPUTE_ADDRESS=
# On-chain governance-role registry (PropChainOracle)
NEXT_PUBLIC_ORACLE_REGISTRY_ADDRESS=
# Optional, per-property fractional vault (deployed on demand)
NEXT_PUBLIC_FRACTIONAL_ADDRESS=
# First block to scan for on-chain history (set to the contract deploy block)
HISTORY_START_BLOCK=0
# Free PolygonScan API key (optional — only for contract verification)
POLYGONSCAN_API_KEY=

# ── Wallet: WalletConnect (free) ─────────────────────────────────────────────
# https://cloud.reown.com (formerly WalletConnect Cloud) → Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── IPFS: Pinata (free tier — 1 GB) ──────────────────────────────────────────
# https://app.pinata.cloud → API Keys → create → copy the JWT
# Leave blank to use a simulated CID (no pinning).
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Email: Resend (free tier — 100/day) ──────────────────────────────────────
# https://resend.com → API Keys. Leave blank to log emails instead of sending.
RESEND_API_KEY=
EMAIL_FROM=PropChain <onboarding@resend.dev>

# ── Oracle / dev admin ───────────────────────────────────────────────────────
# bcrypt hash of the Oracle passphrase (never store the plaintext)
ORACLE_ACCESS_HASH=
# Password gate for the /dev/admin tools (development only)
DEV_ADMIN_PASSWORD=
# Secret used to seal ownership-certificate Verifiable Credentials (HMAC-SHA256).
# Any non-empty value works for the PoC; keep it stable so issued certs verify.
CREDENTIAL_SIGNING_SECRET=

# ── Maps (optional) ──────────────────────────────────────────────────────────
# Left blank: the app shows a free OpenStreetMap location card.
# Mapbox is NOT required and is a paid service beyond its free tier.
NEXT_PUBLIC_MAPBOX_TOKEN=
